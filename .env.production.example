# ============================================================
# 央企海外工程供应链平台 · 生产环境变量模板
#
# 用法:
#   cp .env.production.example .env.production
#   vim .env.production    # 填真实值
#   chmod 600 .env.production
#
# 重要:.env.production 严禁入库(.gitignore 已排除)
# ============================================================

# ----- 数据库(compose 内置 PG 容器,与外部 PG 无关)-----
POSTGRES_DB=overseas_supply
POSTGRES_USER=overseas_app
# 强密码,用 openssl rand -base64 24 生成
POSTGRES_PASSWORD=CHANGEME_strong_random_password

# ----- JWT -----
# 用 openssl rand -hex 32 生成,严禁用示例值
JWT_SECRET_KEY=CHANGEME_openssl_rand_hex_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- 初始 super admin(首次部署后立即改密)-----
SUPER_ADMIN_EMAIL=superadmin@platform.local
SUPER_ADMIN_INITIAL_PASSWORD=CHANGEME_set_strong_initial_password

# ----- demo 账号(演示环境保持 true · 真生产应 false)-----
SEED_DEMO_ACCOUNTS=true

# ----- 公网访问入口 -----
# 前端访问后端的 URL:必须 build 时注入,运行时改无效
# 替换成 ECS 公网 IP(本地验证时可写 http://localhost:8000)
NEXT_PUBLIC_API_BASE_URL=http://YOUR_ECS_PUBLIC_IP:8000

# 后端 CORS 允许的来源(逗号分隔)
# 必须包含前端访问入口(浏览器的 origin)
CORS_ORIGINS=http://YOUR_ECS_PUBLIC_IP:3000
CORS_ALLOW_CREDENTIALS=true

# ----- Refresh token cookie -----
# 纯 HTTP 部署:SECURE=false + SAMESITE=lax(strict 在跨端口时浏览器会拒)
# 后续接 HTTPS:SECURE=true + SAMESITE=strict
REFRESH_COOKIE_NAME=refresh_token
REFRESH_COOKIE_PATH=/api/v1/auth
REFRESH_COOKIE_MAX_AGE=604800
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax

# ----- 登录限流 -----
LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_MAX_FAILURES=5
LOGIN_RATE_LIMIT_LOCK_SECONDS=300

# ----- 日志 -----
LOG_LEVEL=INFO

# ----- 调试 API(生产建议 false)-----
ENABLE_DEBUG_API=false
